## Description: Support for opening databases in DataGrip
## Usage: datagrip
## Example: "ddev datagrip" or "ddev datagrip --database database2" to open a database named "database2"
## Flags: [{"Name":"database","Shorthand":"d","Usage":"Database name"},{"Name":"reset","Shorthand":"r","Usage":"Reset DataGrip datasource. Manual refresh in DataGrip is required after launch"},{"Name":"auto-refresh","Shorthand":"a","Usage":"Sets the interval, in minutes, that DataGrip will refresh the datasource. Minimum 0.1 minute (6 seconds). Set to 0 to disable"},{"Name":"pg-pass","Shorthand":"p","Usage":"Allows projects using Postgres to utilize the .pgpass file instead of storing credentials in the project directory. Passing this argument is required EACH TIME the command is run. While these credentials are still well known and inherently safe to store, using .pgpass may be beneficial, such as organizations that perform scans on commits for credentials."},{"Name":"no-defaults","Shorthand":"n","Usage":"Ignore all per-user config defaults for this invocation; use only CLI flags and hardcoded fallbacks. Useful for overriding a default such as 'pg-pass: true' for a single run. Run 'ddev datagrip config' to manage defaults."}]
## DBTypes: mariadb,mysql,postgres

# ═══════════════════════════════════════════════════════════════════════════
#  Setup — defaults, helpers, helper-library load
# ═══════════════════════════════════════════════════════════════════════════

RESET=false
DATABASE="db"
AUTOREFRESH=1
PGPASS=false

PGPASS_FILE="$HOME/.pgpass"

# DDEV_DATABASE is in the format type:version, like mysql:8 or mariadb:10.6.
# This gets the type part (mysql or mariadb).
DB_TYPE="${DDEV_DATABASE%%:*}"

# Detect platform for WSL handling and version-check path discovery.
# Returns one of: macos, linux, wsl, windows, unknown.
detect_platform() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)
      if [[ -n "${WSL_DISTRO_NAME:-}" ]] || grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *) echo "unknown" ;;
  esac
}

PLATFORM="$(detect_platform)"

# Source helper libraries. SCRIPT_DIR uses BASH_SOURCE so it works regardless
# of how DDEV invokes the script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=datagrip-lib/version-check.sh
source "${SCRIPT_DIR}/datagrip-lib/version-check.sh"
# shellcheck source=datagrip-lib/config.sh
source "${SCRIPT_DIR}/datagrip-lib/config.sh"

# ═══════════════════════════════════════════════════════════════════════════
#  Config subcommand
#
#  If the first argument is "config", route to the config helper and exit.
#  This must run before normal flag parsing so 'ddev datagrip config set ...'
#  doesn't get interpreted as launch-mode flags.
# ═══════════════════════════════════════════════════════════════════════════

if [[ "${1:-}" == "config" ]]; then
  shift
  datagrip_config_subcommand "$@"
  exit $?
fi

# ═══════════════════════════════════════════════════════════════════════════
#  Load defaults (from per-user config, unless --no-defaults is passed)
#
#  Hardcoded defaults are set above (RESET, DATABASE, AUTOREFRESH, etc).
#  Here we override them from the per-user config file if present, before the
#  CLI flag parser runs (so flags still take precedence over config).
#
#  --no-defaults must be detected BEFORE we load user config. We pre-scan the
#  args without consuming them; the main parser still handles the flag.
# ═══════════════════════════════════════════════════════════════════════════

NO_DEFAULTS=false
for arg in "$@"; do
  if [[ "$arg" == "-n" || "$arg" == "--no-defaults" ]]; then
    NO_DEFAULTS=true
    break
  fi
done

if [[ "$NO_DEFAULTS" == false ]]; then
  # Stage user-config values into DEFAULT_* variables, then copy them onto
  # the actual script variables. This keeps the indirection in one place.
  DEFAULT_PG_PASS="$PGPASS"
  DEFAULT_DEFAULT_DATABASE="$DATABASE"
  DEFAULT_AUTO_REFRESH="$AUTOREFRESH"
  datagrip_config_load_user_defaults pg-pass default-database auto-refresh
  PGPASS="$DEFAULT_PG_PASS"
  DATABASE="$DEFAULT_DEFAULT_DATABASE"
  AUTOREFRESH="$DEFAULT_AUTO_REFRESH"
fi

# ═══════════════════════════════════════════════════════════════════════════
#  Argument parsing
# ═══════════════════════════════════════════════════════════════════════════

while :; do
  case ${1:-} in
  -d|--database)
      echo "🔎 --database flag provided, setting database to $2"
      DATABASE="$2"
      shift # Extra shift for the argument value
      ;;
  -r|--reset)
    echo "🧨 --reset flag provided, resetting DataGrip datasource"
    RESET=true
    ;;
  -a|--auto-refresh)
    echo "🔄 --auto-refresh flag provided, setting auto-refresh interval to $2"
    AUTOREFRESH=$2
    if [[ ! "$AUTOREFRESH" =~ ^[0-9]+\.?[0-9]*$ ]]; then
      echo "❌ Error: auto-refresh value '$AUTOREFRESH' is not a valid number"
      exit 1
    fi
    if (( $(echo "$AUTOREFRESH < 0.1" | bc -l) )); then
      if (( $(echo "$AUTOREFRESH <= 0" | bc -l) )); then
        echo "🛑 Auto-refresh set to 0, disabling"
      else
        echo "⚠️ Provided auto-refresh interval of $AUTOREFRESH is less than 0.1. Clamping to 0.1 minutes (6 seconds)"
        AUTOREFRESH=0.1
      fi
    fi
    shift # Extra shift for the argument value
    ;;
  -p|--pg-pass)
    if [[ "$DB_TYPE" != "postgres" ]]; then
      echo "⚠️ --pg-pass cannot be used without a Postgres DB. This project is using $DB_TYPE, so --pg-pass will not affect anything"
    else
      echo "🔄 --pg-pass flag provided, using .pgpass for authentication in DataGrip"
      echo "⚠️ Note that using --pg-pass is a potentially destructive action as it writes to your .pgpass file. This should be safe, but be sure to back up your file, anyway."
      if [[ -f "$PGPASS_FILE" && ! -f "$PGPASS_FILE.bak" ]]; then
        echo "⚠️ As this is the first time --pg-pass has been used, ~/.pgpass.bak file has be created for you as a precaution, which contains the pre-datagrip configuration (if any)"
        cp -p "$PGPASS_FILE" "$PGPASS_FILE.bak"
      fi
      PGPASS=true
    fi
    ;;
  -n|--no-defaults)
    # Already handled in the pre-scan above; consume here so it doesn't fall
    # through to the "Unknown option" branch.
    ;;
  --) # End of all options.
    shift
    break
    ;;
  -?*)
    printf 'WARN: Unknown option (ignored): %s\n' "$1" >&2
    ;;
  *) # Default case: No more options, so break out of the loop.
    break ;;
  esac

  shift
done

# ═══════════════════════════════════════════════════════════════════════════
#  Version detection and script selection
#
#  Runs before we touch the project so version problems abort cleanly before
#  any side effects (file writes, ddev start, etc).
#
#  The user-configured version (if set) always takes precedence. If both a
#  configured and detected version exist and differ, a warning is shown.
# ═══════════════════════════════════════════════════════════════════════════

# Read the user-configured version (always respected, even with --no-defaults)
CONFIGURED_VERSION="$(_dg_yaml_get "$_DG_USER_CONFIG" "datagrip-version")"

# Try to auto-detect the installed version
datagrip_detect_version "$PLATFORM"

if [[ -n "$_DG_DETECTED_VERSION" && -n "$CONFIGURED_VERSION" ]]; then
  if [[ "$_DG_DETECTED_VERSION" != "$CONFIGURED_VERSION" ]]; then
    echo "⚠️  Detected DataGrip ${_DG_DETECTED_VERSION} but datagrip-version is configured as ${CONFIGURED_VERSION}."
    echo "   Using configured version. To clear this override: ddev datagrip config unset datagrip-version"
  fi
  DATAGRIP_VERSION="$CONFIGURED_VERSION"
elif [[ -n "$_DG_DETECTED_VERSION" ]]; then
  DATAGRIP_VERSION="$_DG_DETECTED_VERSION"
elif [[ -n "$CONFIGURED_VERSION" ]]; then
  echo "ℹ️  DataGrip version could not be auto-detected. Using configured version: ${CONFIGURED_VERSION}"
  DATAGRIP_VERSION="$CONFIGURED_VERSION"
else
  echo "❌ Could not detect the installed DataGrip version."
  echo "   Please set your version explicitly:"
  echo "     ddev datagrip config set datagrip-version <version>"
  echo "   Example: ddev datagrip config set datagrip-version 2025.2.5"
  exit 2
fi

# Look up the version-specific configuration script from the manifest
VERSIONS_MANIFEST="${SCRIPT_DIR}/datagrip-lib/versions.json"
if ! datagrip_find_version_script "$DATAGRIP_VERSION" "$VERSIONS_MANIFEST"; then
  exit 2
fi
VERSION_SCRIPT="${_DG_VERSION_SCRIPT}"

# ═══════════════════════════════════════════════════════════════════════════
#  Project state — start the project if it isn't running
# ═══════════════════════════════════════════════════════════════════════════

# Make sure the project is running; if not, start it and re-run this via ddev
if [ "${DDEV_PROJECT_STATUS}" != "running" ] && [ -z "${no_recursion:-}" ]; then
  echo "❌ Project ${DDEV_PROJECT} is not running, starting it"
  ddev start
  start_exit_code=$?
  if [ $start_exit_code -ne 0 ]; then
    exit $start_exit_code
  fi
  # run this script again, as the environment is updated after "ddev start"
  no_recursion=true ddev "$(basename "$0")" "$@"
  exit $?
fi

echo "✅ Project ${DDEV_PROJECT} is running!"
echo "🔄 Preparing DataGrip datasource..."

# Check for first-run for proper messaging later on.
# FIRST_RUN is true if the dataSources subdir doesn't exist yet — DataGrip
# creates that subdir on its first successful introspection, so its presence
# means the user has connected at least once.
#
# Note: FIRST_RUN and RESET are independent. A user can run --reset before
# DataGrip has ever introspected (e.g. to clear a corrupted config), and we
# need reset behavior to fire in that case. Earlier versions used `elif`
# here, which made --reset a no-op when no introspection had happened yet.
if [[ ! -d "${DDEV_APPROOT}/.ddev/datagrip/.idea/dataSources" ]]; then
  FIRST_RUN=true
fi

if [[ "$RESET" == true ]]; then
  rm -rf "${DDEV_APPROOT}/.ddev/datagrip/.idea"
  # Regenerate the project UUID on reset so the new datasource is treated as
  # entirely separate from the old one (no stale keychain / schema-cache ties).
  datagrip_config_regenerate_uuid >/dev/null
fi

# Ensure the .idea directory exists. We do this unconditionally (rather than
# only on --reset) so the script is self-sufficient and doesn't rely on
# install.yaml having pre-created it. Safe to call even when the directory
# already exists.
mkdir -p "${DDEV_APPROOT}/.ddev/datagrip/.idea"

# ═══════════════════════════════════════════════════════════════════════════
#  XML output — dataSources.xml and dataSources.local.xml
#
#  Delegated to the version-specific script selected above. That script is
#  responsible for building the JDBC URL and writing both XML files.
# ═══════════════════════════════════════════════════════════════════════════

IDEA_DIR="${DDEV_APPROOT}/.ddev/datagrip/.idea"
DATASOURCES_FILE="${IDEA_DIR}/dataSources.xml"
DATASOURCES_LOCAL_FILE="${IDEA_DIR}/dataSources.local.xml"

# UUID for the datasource. Read from (or generated into) the project config
# file so each install gets its own UUID and teammates sharing the repo get
# the same one. The UUID stays stable across normal runs to avoid DataGrip
# treating the datasource as new on each launch.
uuid_value="$(datagrip_config_get_uuid)"
if [[ -z "$uuid_value" ]]; then
  echo "❌ Failed to obtain a project UUID. Cannot continue."
  exit 1
fi

# shellcheck source=/dev/null
source "${SCRIPT_DIR}/datagrip-lib/versions/${VERSION_SCRIPT}" || exit $?

echo "✏️ Wrote DataGrip datasource, starting datagrip..."

# ═══════════════════════════════════════════════════════════════════════════
#  First-run / reset banners
# ═══════════════════════════════════════════════════════════════════════════

if [[ "$FIRST_RUN" == true ]]; then
  echo -e "\\a" # Beep for attention
  COLUMNS=$(tput cols)
  echo ""
  title="⚠️ No schema for the DB has been detected ⚠️"
  printf "%*s\n" $(((${#title}+$COLUMNS)/2)) "$title"
  printf "%*s" "$COLUMNS" | tr ' ' '-'
  echo "If this is your first time connecting to the DB, no schema has been generated."
  echo "Due to DataGrip limitations, you must manually refresh the datasource in DataGrip to generate the schema"
  echo "You should not need to manually refresh again unless you manually delete the project or datasource, or run 'ddev datagrip --reset'"
  printf "%*s" "$COLUMNS" | tr ' ' '-'
  echo ""
elif [[ "$RESET" == true ]]; then
  echo -e "\\a" # Beep for attention
  COLUMNS=$(tput cols)
  echo ""
  title="⚠️ DataGrip datasource has been reset ⚠️"
  printf "%*s\n" $(((${#title}+$COLUMNS)/2)) "$title"
  printf "%*s" "$COLUMNS" | tr ' ' '-'
  echo "DataGrip datasource has been reset. You must manually refresh the datasource in DataGrip."
  echo "You should not need to manually refresh again unless you manually delete the project or datasource, or run 'ddev datagrip --reset'"
  printf "%*s" "$COLUMNS" | tr ' ' '-'
  echo ""
fi

# ═══════════════════════════════════════════════════════════════════════════
#  Launch — locate the DataGrip binary and open the project
#
#  On WSL we have to translate the project path to a Windows path because
#  datagrip64.exe is a Win32 binary and can't read /home/... paths.
# ═══════════════════════════════════════════════════════════════════════════

DATAGRIP_PROJECT_PATH="${DDEV_APPROOT}/.ddev/datagrip"

launch_datagrip() {
  local project_path="$1"
  local translated_path="$project_path"
  local candidates=()

  case "$PLATFORM" in
    macos|linux|unknown)
      # `datagrip` on PATH covers Toolbox shims, Homebrew, and most Linux
      # tarball/distro installs.
      datagrip "$project_path"
      ;;
    wsl)
      # Translate the WSL path so datagrip64.exe can read it.
      if command -v wslpath >/dev/null 2>&1; then
        translated_path="$(wslpath -w "$project_path")"
      fi

      # Try datagrip64.exe / datagrip.exe on PATH first.
      candidates=(datagrip64.exe datagrip.exe)
      for bin in "${candidates[@]}"; do
        if command -v "$bin" >/dev/null 2>&1; then
          "$bin" "$translated_path"
          return $?
        fi
      done

      # PATH miss — probe common install locations under the Windows user dir.
      local win_user
      win_user="$(cmd.exe /c 'echo %USERNAME%' 2>/dev/null | tr -d '\r')"
      if [[ -n "$win_user" ]]; then
        local toolbox_glob="/mnt/c/Users/${win_user}/AppData/Local/Programs/DataGrip/bin/datagrip64.exe"
        local toolbox_apps_glob="/mnt/c/Users/${win_user}/AppData/Local/JetBrains/Toolbox/apps/datagrip/bin/datagrip64.exe"
        local pf_glob="/mnt/c/Program Files/JetBrains/DataGrip*/bin/datagrip64.exe"
        # The unquoted glob expansion lets the shell match versioned install dirs.
        for path_glob in "$toolbox_glob" "$toolbox_apps_glob" $pf_glob; do
          if [[ -x "$path_glob" ]]; then
            "$path_glob" "$translated_path"
            return $?
          fi
        done
      fi

      echo "❌ Could not find datagrip64.exe."
      echo "   On WSL, install DataGrip on Windows (not inside WSL) and either:"
      echo "   - Add its bin/ directory to your Windows PATH, or"
      echo "   - Enable 'Generate shell scripts' in JetBrains Toolbox settings."
      return 1
      ;;
    windows)
      # Git Bash / MSYS / Cygwin on Windows. Path needs cygpath conversion.
      if command -v cygpath >/dev/null 2>&1; then
        translated_path="$(cygpath -w "$project_path")"
      fi
      candidates=(datagrip64.exe datagrip.exe datagrip)
      for bin in "${candidates[@]}"; do
        if command -v "$bin" >/dev/null 2>&1; then
          "$bin" "$translated_path"
          return $?
        fi
      done
      echo "❌ Could not find datagrip64.exe on PATH."
      return 1
      ;;
  esac
}

launch_datagrip "$DATAGRIP_PROJECT_PATH"
